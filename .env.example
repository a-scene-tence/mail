# === 메일 백엔드(Vercel 서버리스 /api/*)에서만 사용 ===
# 실제 값은 .env(커밋 금지)에 넣는다. 클라이언트에 노출 금지.

# Google OAuth (Gmail API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 콜백 URL — Google Cloud 콘솔의 "승인된 리디렉션 URI"와 정확히 일치해야 함
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/google/callback

# OAuth 콜백 후 돌아올 프론트 베이스 URL (예: https://your-app.vercel.app)
APP_BASE_URL=

# 자격증명 암호화용 대칭키 — 32바이트 hex(64자).
# 생성 예: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# 자격증명 저장소 선택: 'kv' 면 Vercel KV, 아니면 memory(개발용, 비영속)
CREDENTIAL_STORE=
# Vercel KV (CREDENTIAL_STORE=kv 일 때)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# === 프론트엔드에서 사용 (NEXT_PUBLIC_ 접두사 필요) ===
# 메일 백엔드 베이스 URL. 비우면 같은 오리진(/api)을 사용.
NEXT_PUBLIC_API_BASE_URL=
